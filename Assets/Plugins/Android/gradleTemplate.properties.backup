org.gradle.jvmargs=-Xmx4096m
org.gradle.daemon=true
org.gradle.parallel=true

# CRÍTICO: redirigir el Gradle user home a una ruta sin caracteres especiales.
# El path por defecto C:\Users\DEPTO DE USO PÚBLICO\.gradle\ contiene Ú (UTF-8 c3 9a)
# que CMD.EXE interpreta con codepage OEM (cp850) corrompiendo el path del JAR
# de Prefab CLI → ClassNotFoundException: com.google.prefab.cli.AppKt
org.gradle.user.home=C\:/gradle
